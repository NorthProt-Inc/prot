# ─── API Keys ───────────────────────────────────────────────
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
VOYAGE_API_KEY=

# ─── Audio ──────────────────────────────────────────────────
# PyAudio input device index (omit or leave empty for system default)
# MIC_DEVICE_INDEX=
# SAMPLE_RATE=16000
# CHUNK_SIZE=512

# ─── VAD ───────────────────────────────────────────────────
# BARGE_IN_ENABLED=false
# VAD_THRESHOLD=0.5
# VAD_THRESHOLD_SPEAKING=0.8
# VAD_PREBUFFER_CHUNKS=8

# ─── STT ───────────────────────────────────────────────────
# STT_LANGUAGE=ko
# STT_SILENCE_THRESHOLD_SECS=3.0

# ─── LLM ───────────────────────────────────────────────────
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MAX_TOKENS=4096
# CLAUDE_EFFORT=high
# COMPACTION_TRIGGER=50000
# TOOL_CLEAR_TRIGGER=30000
# TOOL_CLEAR_KEEP=3
# THINKING_KEEP_TURNS=2

# ─── TTS ────────────────────────────────────────────────────
ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_v3
# ELEVENLABS_OUTPUT_FORMAT=pcm_24000
# TTS_SENTENCE_SILENCE_MS=200

# ─── Home Assistant ─────────────────────────────────────────
HASS_URL=http://localhost:8123
HASS_TOKEN=
# HASS_AGENT_ID=conversation.google_ai_conversation

# ─── Database (PostgreSQL + pgvector) ───────────────────────
DATABASE_URL=postgresql://prot:prot@localhost:5432/prot
# DB_POOL_MIN=2
# DB_POOL_MAX=10

# ─── Embeddings / Reranker ──────────────────────────────────
# VOYAGE_MODEL=voyage-4-large
# RERANK_MODEL=rerank-2.5
# RERANK_TOP_K=5

# ─── Memory ─────────────────────────────────────────────────
# MEMORY_EXTRACTION_MODEL=claude-haiku-4-5-20251001
# RAG_CONTEXT_TARGET_TOKENS=4096
# RAG_TOP_K=10
# PAUSE_AFTER_COMPACTION=true
# DECAY_BASE_RATE=0.002
# DECAY_MIN_RETENTION=0.1

# ─── CORS ───────────────────────────────────────────────────
# CORS_ORIGINS=["http://localhost:3000"]

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Timers ─────────────────────────────────────────────────
# ACTIVE_TIMEOUT=30
